{
  "name": "agenticons",
  "version": "0.3.0",
  "description": "AI & agent icons for React — 51 icons for agents, MCP, tool calls, RAG, tokens, context windows, evals. Lucide-compatible, tree-shakeable, TypeScript, MIT.",
  "keywords": [
    "icons",
    "icon",
    "svg",
    "react",
    "react-icons",
    "ai",
    "ai-icons",
    "agent",
    "agents",
    "agentic",
    "llm",
    "mcp",
    "model-context-protocol",
    "rag",
    "chatbot",
    "lucide",
    "heroicons"
  ],
  "homepage": "https://josharsh.github.io/agenticons/",
  "license": "MIT",
  "author": "Harsh Joshi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josharsh/agenticons.git"
  },
  "bugs": "https://github.com/josharsh/agenticons/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./icons/*": {
      "types": "./dist/types/icons/*.d.ts",
      "import": "./dist/esm/icons/*.js",
      "require": "./dist/cjs/icons/*.cjs"
    },
    "./svg/*.svg": "./dist/svg/*.svg",
    "./metadata.json": "./dist/metadata.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "npm run build && node --test test/",
    "typecheck": "npm run build && tsc -p tsconfig.json",
    "preview": "node scripts/preview.mjs",
    "prepublishOnly": "npm run test && npm run typecheck",
    "gallery": "node scripts/gallery.mjs"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
